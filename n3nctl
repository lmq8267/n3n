#!/bin/ash  
  
# n3n状态获取脚本 - 基于management_script.js  
# 适用于嵌入式busybox环境，无jq依赖  
  
# 颜色定义  
GREEN='\033[92m'  
PURPLE='\033[95m'  
CYAN='\033[96m'  
BLUE='\033[94m'  
YELLOW='\033[93m'  
RED='\033[91m'  
WHITE='\033[97m'  
NC='\033[0m' # No Color
  
# 详细输出标志  
VERBOSE=0
MGMT_PASSWORD="n3n"  # 默认管理密码
  
# 检查参数  
if [ "$1" = "-v" ] || [ "$1" = "-V" ] || [ "$1" = "v" ] || [ "$1" = "V" ]; then  
    VERBOSE=1
    echo -e "${CYAN}详细模式已开启${NC}"
fi  

# 格式化响应
result_j() {
    echo "$1" | sed 's/.*"result":\s*\(.*\)}/\1/' | sed 's/^\s*\[\s*//;s/\s*\]\s*$//'
}

# ===== 获取管理端口（带循环校验） =====
while true; do
    echo ""
    echo -n "请输入管理端口 (edge默认5644 / supernode默认5645，输入0退出): "
    read PORT
    echo ""

    # 输入0退出
    if [ "$PORT" = "0" ]; then
        echo -e "${YELLOW}用户选择退出脚本${NC}"
        exit 0
    fi

    # 判空
    if [ -z "$PORT" ]; then
        echo -e "${RED}端口不能为空，请重新输入！${NC}"
        continue
    fi

    # 必须是数字
    echo "$PORT" | grep -q '^[0-9]\+$'
    if [ $? -ne 0 ]; then
        echo -e "${RED}端口必须是数字，请重新输入！${NC}"
        continue
    fi

    # 端口范围校验
    if [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
        echo -e "${RED}端口范围必须在1-65535之间！${NC}"
        continue
    fi

    # 校验通过
    break
done
URL="http://[::1]:$PORT/v1"  
  
# HTTP请求函数，wget失败时回退到curl  
http_request() {  
    local data="$1"
    local use_auth="$2"  # 是否使用认证
    local response=""  
      
    if [ $VERBOSE -eq 1 ]; then  
        echo -e "${YELLOW}请求URL: $URL ${NC}" >&2
        echo -e "${YELLOW}请求数据: $data ${NC}" >&2
    fi  
    
    # 构建认证头  
    local auth_header=""
    if [ "$use_auth" = "1" ] && [ -n "$MGMT_PASSWORD" ]; then  
        auth_header="Authorization: Basic $(echo -n "unused:$MGMT_PASSWORD" | base64)"  
    fi
    if type wget >/dev/null 2>&1; then    
        if [ -n "$auth_header" ]; then  
            response=$(wget -q -O - --header="$auth_header" --post-data="$data" "$URL" 2>/dev/null)  
        else  
            response=$(wget -q -O - --post-data="$data" "$URL" 2>/dev/null)  
        fi  
    elif type curl >/dev/null 2>&1; then    
        if [ -n "$auth_header" ]; then  
            response=$(curl -s -X POST -H "$auth_header" -d "$data" "$URL" 2>/dev/null)  
        else  
            response=$(curl -s -X POST -d "$data" "$URL" 2>/dev/null)  
        fi  
    else    
        echo -e "${RED}错误: 需要wget或curl \n$(which wget)\n$(which curl)${NC}"    
        exit 1    
    fi  
      
    if [ $VERBOSE -eq 1 ]; then  
        echo -e "${YELLOW}原始响应: $response ${NC}" >&2
    fi  
      
    echo "$response"  
}  
  
# 检查连接是否成功  
check_connection() {  
    local test_response=$(http_request '{"jsonrpc":"2.0","method":"get_verbose","params":null,"id":1}')  
      
    if [ -z "$test_response" ]; then  
        echo -e "${RED}错误: 无法连接到管理端口 $PORT${NC}"  
        echo -e "${RED}请检查:${NC}"  
        echo -e "${RED}1. 管理端口是否正确${NC}"  
        echo -e "${RED}2. n3n程序是否正在运行${NC}"  
        echo -e "${RED}3. 防火墙设置是否正确${NC}"  
        exit 1  
    fi  
      
    if echo "$test_response" | grep -q '"error"'; then  
        echo -e "${RED}错误: 服务器返回错误响应${NC}"  
        echo -e "${RED}响应: $test_response${NC}"  
        exit 1  
    fi  
}  
  
# JSON-RPC请求函数  
jsonrpc_request() {  
    local method="$1"
    local params="$2"
    local use_auth="$3"  # 是否需要认证，默认为0
    [ -z "$use_auth" ] && use_auth="0"
    
    local json_data="{\"jsonrpc\":\"2.0\",\"method\":\"$method\",\"params\":$params,\"id\":1}"  
    http_request "$json_data" "$use_auth"
}  
  
# JSON解析函数 - 提取result字段  
extract_json_result() {  
    local json="$1"  
    echo "$json" | sed 's/.*"result":\s*//; s/}}.*$/}/' | sed 's/}$//'  
}  
  
# 从JSON中提取字符串值  
extract_json_string() {  
    local json="$1"  
    local field="$2"  
    echo "$json" | sed -n "s/.*\"$field\":\s*\"\([^\"]*\)\".*/\1/p" | head -1  
}  
  
# 从JSON中提取数字值  
extract_json_number() {  
    local json="$1"  
    local field="$2"  
    echo "$json" | sed -n "s/.*\"$field\":\s*\([0-9]*\).*/\1/p" | head -1  
}  
  
# 日志等级转中文  
verbose_to_chinese() {  
    case "$1" in  
        0) echo "0 错误-ERROR" ;;  
        1) echo "1 警告-WARNING" ;;  
        2) echo "2 正常-NORMAL" ;;  
        3) echo "3 信息-INFO" ;;  
        4) echo "4 调试-DEBUG" ;;  
        *) echo "$1" ;;  
    esac  
}  
  
# 表头转中文  
header_to_chinese() {  
    case "$1" in  
        'version') echo "版本" ;;  
        'current') echo "当前状态" ;;  
        'macaddr') echo "MAC地址" ;;  
        'sockaddr') echo "连接地址" ;;  
        'uptime') echo "运行时间" ;;  
        'mode') echo "模式" ;;  
        'ip4addr') echo "IP地址" ;;  
        'desc') echo "描述" ;;  
        'type') echo "类型" ;;  
        'tx_pkt') echo "发送包" ;;  
        'rx_pkt') echo "接收包" ;;  
        'community') echo "社区名称" ;;  
        'last_register_req') echo "最后注册请求" ;;  
        'last_rx_p2p') echo "最后P2P接收" ;;  
        'last_rx_super') echo "最后supernode接收" ;;  
        'last_sweep') echo "最后清理" ;;  
        'last_sn_fwd') echo "最后supernode转发" ;;  
        'last_sn_reg') echo "最后supernode注册" ;;  
        'start_time') echo "启动时间" ;;  
        *) echo "$1" ;;  
    esac  
}  
  
# 值转中文  
value_to_chinese() {  
    local key="$1"
    local value="$2"
      
    case "$key" in  
        'mode')  
            case "$value" in  
                'pSp') echo "supernode转发" ;;  
                'p2p') echo "P2P直连" ;;  
                'sn') echo "supernode注册" ;;  
                *) echo "$value" ;;  
            esac  
            ;;  
        'type')  
            case "$value" in  
                'transop') echo "转换操作" ;;  
                'p2p') echo "P2P直连" ;;  
                'super') echo "supernode" ;;  
                'super_broadcast') echo "supernode广播" ;;  
                'tuntap_error') echo "TUN/TAP错误" ;;  
                'multicast_drop') echo "组播丢弃" ;;  
                'sn_fwd') echo "supernode转发" ;;  
                'sn_broadcast') echo "supernode广播" ;;  
                'sn_reg') echo "supernode注册" ;;  
                'sn_errors') echo "supernode错误" ;;  
                *) echo "$value" ;;  
            esac  
            ;;
        'current')
            case "$value" in  
                0) echo "0 非当前" ;;  
                1) echo "1 当前" ;;  
                2) echo "2 等待中" ;;  
                *) echo "$value" ;;  
            esac
            ;;  
        *)  
            echo "$value"  
            ;;
    esac  
}  
  
# 格式化Unix时间戳  
format_unix_timestamp() {  
    local timestamp="$1"  
    if [ "$timestamp" = "0" ] || [ -z "$timestamp" ]; then  
        echo "从未"
        return
    fi  
    date -d "@$timestamp" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "$timestamp"
}  
  
# 格式化运行时间  
format_uptime() {  
    local seconds="$1"
    if [ "$seconds" = "0" ] || [ -z "$seconds" ]; then  
        echo "0秒"  
        return  
    fi  
      
    local days=$((seconds / 86400))  
    local hours=$(((seconds % 86400) / 3600))  
    local minutes=$(((seconds % 3600) / 60))  
    local secs=$((seconds % 60))  
      
    local result=""  
    [ $days -gt 0 ] && result="${result}${days}天 "  
    [ $hours -gt 0 ] && result="${result}${hours}小时 "  
    [ $minutes -gt 0 ] && result="${result}${minutes}分钟 "  
    [ $secs -gt 0 -o -z "$result" ] && result="${result}${secs}秒"  
      
    echo "$result" | sed 's/ *$//'  
}  
  
# 获取并显示日志等级  
get_verbose() {  
    local result="$(jsonrpc_request "get_verbose" "null")"  
    local verbose_value="$(echo "$result" | sed 's/.*"result":\s*//; s/[},].*//')" 
      
    echo -e "${PURPLE}日志等级：${PURPLE} ${CYAN}$(verbose_to_chinese "$verbose_value")${NC}"  
}  
  
# 获取并显示社区信息  
get_communities() {  
    local result="$(jsonrpc_request "get_communities" "null")"  
    local community="$(echo "$result" | sed -n 's/.*"community":\s*"\([^"]*\)".*/\1/p' | head -1)"  
    
    echo -e "${PURPLE}社区名称：${PURPLE} ${CYAN}${community}${NC}"  
}  
  
# 获取并显示Edges/Peers 
get_edges() {  
    echo -e "${BLUE}### Edges/Peers ###${NC}"  
    local result="$(jsonrpc_request "get_edges" "null")"  
      
    local result_json="$(result_j "$result")"
    
    if [ "$result_json" = "[]" ] || [ -z "$result_json" ]; then
        echo -e "无数据"
        return  
    fi  
      
    if [ $VERBOSE -eq 1 ]; then  
        echo -e "${YELLOW}Edges原始响应: $result${NC}" >&2
    fi  
      
    # JSON数组解析 - 处理每个对象  
    echo "$result" | sed 's/},{/}\n{/g' | sed 's/\[//g; s/\]//g' | while read -r line; do  
        if echo "$line" | grep -q '"mode"'; then
        mode="$(echo "$line" | extract_json_string "$line" "mode")"  
            ip4addr="$(echo "$line" | extract_json_string "$line" "ip4addr")"  
            macaddr="$(echo "$line" | extract_json_string "$line" "macaddr")"  
            sockaddr="$(echo "$line" | extract_json_string "$line" "sockaddr")"  
            desc="$(echo "$line" | extract_json_string "$line" "desc")"  
            uptime="$(echo "$line" | extract_json_number "$line" "uptime")"  
              
            if [ $VERBOSE -eq 1 ]; then  
                echo -e "${YELLOW}解析Edge - 模式: $mode, IP: $ip4addr, MAC: $macaddr${NC}" >&2
            fi  
              
            echo -e "${PURPLE}模式：${PURPLE} ${CYAN}$(value_to_chinese "mode" "$mode")${NC}"  
            echo -e "${PURPLE}IP地址：${PURPLE} ${CYAN}${ip4addr}${NC}"  
            echo -e "${PURPLE}MAC地址：${PURPLE} ${CYAN}${macaddr}${NC}"  
            echo -e "${PURPLE}连接地址：${PURPLE} ${CYAN}${sockaddr}${NC}"  
            echo -e "${PURPLE}描述：${PURPLE} ${CYAN}${desc}${NC}"  
            echo -e "${PURPLE}运行时间：${PURPLE} ${CYAN}$(format_uptime "$uptime")${NC}"  
            echo  
        fi  
    done  
}  
  
# 获取并显示Supernodes  
get_supernodes() {  
    echo -e "${BLUE}### Supernodes ###${NC}"  
    local result="$(jsonrpc_request "get_supernodes" "null")"  
      
    local result_json="$(result_j "$result")"
    
    if [ "$result_json" = "[]" ] || [ -z "$result_json" ]; then
        echo -e "无数据"  
        return  
    fi  
      
    if [ $VERBOSE -eq 1 ]; then  
        echo -e "${YELLOW}Supernodes原始响应: $result${NC}" >&2
    fi  
      
    echo "$result" | sed 's/},{/}\n{/g' | sed 's/\[//g; s/\]//g' | while read -r line; do  
        if echo "$line" | grep -q '"version"'; then  
            version="$(echo "$line" | extract_json_string "$line" "version")"  
            current="$(echo "$line" | extract_json_number "$line" "current")"  
            macaddr="$(echo "$line" | extract_json_string "$line" "macaddr")"  
            sockaddr="$(echo "$line" | extract_json_string "$line" "sockaddr")"  
            uptime="$(echo "$line" | extract_json_number "$line" "uptime")"  
              
            if [ $VERBOSE -eq 1 ]; then  
                echo -e "${YELLOW}解析Supernode - 版本: $version, 当前: $current, MAC: $macaddr${NC}" >&2
            fi  
              
            echo -e "${PURPLE}版本：${PURPLE} ${CYAN}${version}${NC}"  
            echo -e "${PURPLE}当前状态：${PURPLE} ${CYAN}$(value_to_chinese "current" "$current")${NC}"  
            echo -e "${PURPLE}MAC地址：${PURPLE} ${CYAN}${macaddr}${NC}"  
            echo -e "${PURPLE}连接地址：${PURPLE} ${CYAN}${sockaddr}${NC}"  
            echo -e "${PURPLE}运行时间：${PURPLE} ${CYAN}$(format_uptime "$uptime")${NC}"  
            echo  
        fi  
    done  
}  
  
# 获取并显示时间戳  
get_timestamps() {  
    echo -e "${BLUE}### 时间戳 ###${NC}"  
    local result="$(jsonrpc_request "get_timestamps" "null")"  
      
    if [ $VERBOSE -eq 1 ]; then  
        echo -e "${YELLOW}时间戳原始响应: $result${NC}" >&2
    fi  
      
    # 时间戳是单个对象，不是数组  
    for field in last_register_req last_rx_p2p last_rx_super last_sweep last_sn_fwd last_sn_reg start_time; do  
        value="$(echo "$result" | extract_json_number "$result" "$field")"  
        chinese_header="$(header_to_chinese "$field")"  
        formatted_time="$(format_unix_timestamp "$value")"  
          
        if [ $VERBOSE -eq 1 ]; then  
            echo -e "${YELLOW}解析时间戳 $field: $value -> $formatted_time${NC}" >&2
        fi  
          
        echo -e "${PURPLE}${chinese_header}：${PURPLE} ${CYAN}${formatted_time}${NC}"  
    done  
}  
  
# 获取并显示数据包统计  
get_packetstats() {  
    echo -e "${BLUE}### 数据包统计 ###${NC}"  
    local result="$(jsonrpc_request "get_packetstats" "null")"  
      
    local result_json="$(result_j "$result")"
    
    if [ "$result_json" = "[]" ] || [ -z "$result_json" ]; then
        echo -e "无数据"
        return  
    fi  
      
    if [ $VERBOSE -eq 1 ]; then  
        echo -e "${YELLOW}数据包统计原始响应: $result${NC}"  
    fi  
      
    # 分割数组中的每个对象  
    echo "$result" | sed 's/},{/}\n{/g' | sed 's/\[//g; s/\]//g' | while read -r line; do  
        if echo "$line" | grep -q '"type"'; then  
            type="$(echo "$line" | extract_json_string "$line" "type")"  
            tx_pkt="$(echo "$line" | extract_json_number "$line" "tx_pkt")"  
            rx_pkt="$(echo "$line" | extract_json_number "$line" "rx_pkt")"  
              
            chinese_type="$(value_to_chinese "type" "$type")"  
              
            if [ $VERBOSE -eq 1 ]; then  
                echo -e "${YELLOW}解析数据包统计 - 类型: $type, 发送: $tx_pkt, 接收: $rx_pkt${NC}" >&2
            fi  
              
            echo -e "${PURPLE}类型：${PURPLE} ${CYAN}${chinese_type}${NC}"  
            echo -e "${PURPLE}发送包：${PURPLE} ${CYAN}${tx_pkt}${NC}"  
            echo -e "${PURPLE}接收包：${PURPLE} ${CYAN}${rx_pkt}${NC}"  
            echo  
        fi  
    done  
}  

# 获取并显示MAC地址路由信息  
get_mac() {  
    echo -e "${BLUE}### MAC地址路由 ###${NC}"  
    local result="$(jsonrpc_request "get_mac" "null")"  
    local result_json="$(result_j "$result")"
    
    if [ "$result_json" = "[]" ] || [ -z "$result_json" ]; then
        echo -e "无数据"  
        return  
    fi  
      
    echo "$result" | sed 's/},{/}\n{/g' | sed 's/\[//g; s/\]//g' | while read -r line; do  
        if echo "$line" | grep -q '"mac"'; then  
            type="$(echo "$line" | extract_json_string "$line" "_type")"  
            mac="$(echo "$line" | extract_json_string "$line" "mac")"  
            dest="$(echo "$line" | extract_json_string "$line" "dest")"  
            last_seen="$(echo "$line" | extract_json_number "$line" "last_seen")"  
              
            # 计算年龄  
            now=$(date +%s)  
            age=$((now - last_seen))  
            age_str="$(format_uptime $age)"  
              
            echo -e "${PURPLE}类型：${PURPLE} ${CYAN}${type}${NC}"  
            echo -e "${PURPLE}MAC地址：${PURPLE} ${CYAN}${mac}${NC}"  
            echo -e "${PURPLE}目标：${PURPLE} ${CYAN}${dest}${NC}"  
            echo -e "${PURPLE}年龄：${PURPLE} ${CYAN}${age_str}${NC}"  
            echo  
        fi  
    done  
}
  
# 显示当前时间  
show_current_time() {  
    echo -e "${PURPLE}当前时间：${PURPLE} ${CYAN}$(date '+%Y-%m-%d %H:%M:%S')${NC}"  
}

# 设置日志等级  
set_verbose_level() {  
    echo -e "${BLUE}### 设置日志等级 ###${NC}\n"  
    echo -n "请输入密码 (默认n3n，直接回车使用默认): "  
    read password  
    echo ""  
      
    if [ -z "$password" ]; then  
        password="n3n"  
    fi  
      
    # 临时设置密码用于认证  
    local old_password="$MGMT_PASSWORD"  
    MGMT_PASSWORD="$password"  
      
    while true; do  
        echo ""  
        echo -e "请选择日志等级：\n" 
        echo "0 - 错误-ERROR"  
        echo "1 - 警告-WARNING"   
        echo "2 - 正常-NORMAL"  
        echo "3 - 信息-INFO"  
        echo "4 - 调试-DEBUG"  
        echo "5 - 返回上级菜单"  
        echo ""
        echo -n "请输入选择 (0-5): "  
        read choice  
          
        case "$choice" in  
            0|1|2|3|4)  
                local result="$(jsonrpc_request "set_verbose" "[$choice]" "1")"  
                if echo "$result" | grep -q '"error"'; then  
                    echo -e "${RED}错误: 密码错误或设置失败${NC}\n"  
                else  
                    echo -e "${GREEN}日志等级已设置为: $(verbose_to_chinese "$choice")${NC}\n"  
                fi  
                MGMT_PASSWORD="$old_password"  
                return  
                ;;  
            5)  
                MGMT_PASSWORD="$old_password"  
                return  
                ;;  
            *)  
                echo -e "${RED}输入错误，请输入0-5${NC}"  
                ;;  
        esac  
    done  
}  
  
# 停止程序运行  
stop_program() {  
    echo -e "${BLUE}### 停止程序运行 ###${NC}\n"  
    echo -n "请输入密码 (默认n3n，直接回车使用默认): "  
    read password  
    echo ""  
      
    if [ -z "$password" ]; then  
        password="n3n"  
    fi  
      
    echo -n "确认停止程序运行? (Y/y停止, N/n返回): "  
    read confirm  
      
    case "$confirm" in  
        [Yy]|[Yy][Ee][Ss])  
            local old_password="$MGMT_PASSWORD"  
            MGMT_PASSWORD="$password"  
            local result="$(jsonrpc_request "stop" "null" "1")"  
            if echo "$result" | grep -q '"error"'; then  
                echo -e "${RED}错误: 密码错误或停止失败${NC}\n"  
            else  
                echo -e "${GREEN}程序已停止${NC}\n"
                exit 0
            fi  
            MGMT_PASSWORD="$old_password"  
            ;;  
        [Nn]|[Nn][Oo])  
            echo "操作已取消"  
            return  
            ;;  
        *)  
            echo -e "${RED}无效选择，返回菜单${NC}"  
            ;;  
    esac  
}  
  
# 显示主菜单  
show_menu() {  
    echo ""  
    echo -e "${GREEN}=== 操作菜单 ===${NC}\n"  
    echo "1. 重新获取数据"  
    echo "2. 停止程序运行"  
    echo "3. 设置日志等级"  
    echo "4. 退出当前脚本"  
    echo ""
    echo -n "请选择操作 (1-4): "  
    echo ""
}  
  
# 主菜单循环  
menu_loop() {  
    while true; do  
        show_menu  
        read choice  
          
        case "$choice" in  
            1)  
                echo -e "${YELLOW}重新获取数据...${NC}"  
                echo ""  
                main  
                ;;  
            2)  
                stop_program  
                ;;  
            3)  
                set_verbose_level  
                ;;  
            4)  
                echo -e "${GREEN}退出脚本${NC}"  
                exit 0  
                ;;  
            *)  
                echo -e "${RED}无效选择，请输入1-4${NC}"  
                ;;  
        esac  
    done  
} 
  
# 主函数  
main() {  
    echo -e "\n${GREEN}=== n3n 状态信息 ===${NC}"  
    echo  
      
    # 检查连接  
    check_connection  
      
    # 获取并显示所有状态信息  
    get_verbose  
    echo  
    get_communities  
    echo  
    get_edges  
    get_supernodes  
    get_timestamps  
    echo  
    get_packetstats  
    echo  
    get_mac
    echo  
    show_current_time

    # 进入菜单循环  
